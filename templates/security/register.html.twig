{% extends "base.html.twig" %}

{% block title %}Inscription - Le Bistrot Français{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow border-0">
                <div class="card-header bg-white border-0 pt-4">
                    <div class="text-center mb-3">
                        <i class="fas fa-user-plus fa-3x" style="color: var(--accent-color);"></i>
                    </div>
                    <h1 class="h2 text-center mb-0">Créer votre compte</h1>
                    <p class="text-center text-muted mb-0">Réservez vos tables en ligne et gérez vos visites</p>
                </div>
                <div class="card-body p-4">
                    {{ form_start(registrationForm) }}
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(registrationForm.nom) }}
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-user"></i>
                                    </span>
                                    {{ form_widget(registrationForm.nom, {'attr': {'class': 'form-control', 'placeholder': 'Votre nom complet'}}) }}
                                </div>
                                {{ form_errors(registrationForm.nom) }}
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                {{ form_label(registrationForm.email) }}
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-envelope"></i>
                                    </span>
                                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'exemple@email.com'}}) }}
                                </div>
                                {{ form_errors(registrationForm.email) }}
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(registrationForm.plainPassword.first) }}
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-lock"></i>
                                    </span>
                                    {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control', 'placeholder': 'Minimum 6 caractères'}}) }}
                                </div>
                                {{ form_errors(registrationForm.plainPassword.first) }}
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                {{ form_label(registrationForm.plainPassword.second) }}
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-lock"></i>
                                    </span>
                                    {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control', 'placeholder': 'Confirmez votre mot de passe'}}) }}
                                </div>
                                {{ form_errors(registrationForm.plainPassword.second) }}
                            </div>
                        </div>
                        
                        <div class="mb-4 form-check">
                            <input type="checkbox" class="form-check-input" id="newsletter" checked>
                            <label class="form-check-label" for="newsletter">
                                Je souhaite recevoir les actualités et offres spéciales du Bistrot Français
                            </label>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-check-circle me-2"></i>Créer mon compte
                            </button>
                            <a href="{{ path('app_login') }}" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Déjà un compte ? Se connecter
                            </a>
                        </div>
                    {{ form_end(registrationForm) }}
                </div>
            </div>
            
            <div class="card mt-4 border-0 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="mb-3">Pourquoi créer un compte ?</h5>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <i class="fas fa-calendar-check fa-2x mb-2" style="color: var(--accent-color);"></i>
                            <h6>Réservation en ligne</h6>
                            <small class="text-muted">Réservez 24h/24 en quelques clics</small>
                        </div>
                        <div class="col-md-4 mb-3">
                            <i class="fas fa-history fa-2x mb-2" style="color: var(--accent-color);"></i>
                            <h6>Historique</h6>
                            <small class="text-muted">Consultez toutes vos réservations passées</small>
                        </div>
                        <div class="col-md-4 mb-3">
                            <i class="fas fa-gift fa-2x mb-2" style="color: var(--accent-color);"></i>
                            <h6>Avantages</h6>
                            <small class="text-muted">Bénéficiez d'offres spéciales réservées aux membres</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}