{% extends "base.html.twig" %}

{% block title %}Mes réservations - Le Bistrot Français{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2 sidebar">
            <nav class="nav flex-column">
                <h6 class="px-3 mb-3 text-uppercase text-light opacity-75">Espace Client</h6>
                
                <a class="nav-link" href="{{ path('app_client_dashboard') }}">
                    <i class="fas fa-tachometer-alt"></i> Tableau de bord
                </a>
                
                <a class="nav-link active" href="{{ path('app_client_reservations') }}">
                    <i class="fas fa-calendar-check"></i> Mes réservations
                </a>
                
                <a class="nav-link" href="{{ path('app_client_reservation_new') }}">
                    <i class="fas fa-plus-circle"></i> Nouvelle réservation
                </a>
                
                <a class="nav-link" href="{{ path('app_client_carte') }}">
                    <i class="fas fa-utensils"></i> Notre carte
                </a>
                
                <a class="nav-link" href="{{ path('app_client_profile') }}">
                    <i class="fas fa-user-cog"></i> Mon profil
                </a>
            </nav>
        </div>
        
        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 content-area">
            <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2 mb-0">
                    <i class="fas fa-calendar-check me-2"></i>
                    Mes réservations
                </h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="{{ path('app_client_reservation_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus-circle me-2"></i> Nouvelle réservation
                    </a>
                </div>
            </div>

            <!-- Messages flash -->
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            <!-- Réservations à venir -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-calendar-alt me-2"></i>
                        Réservations à venir
                    </h5>
                </div>
                <div class="card-body">
                    {% set futureReservations = reservations|filter(r => r.date >= date('today') and r.status in ['en_attente', 'confirmée']) %}
                    
                    {% if futureReservations|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Heure</th>
                                        <th>Table</th>
                                        <th>Personnes</th>
                                        <th>Statut</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for reservation in futureReservations %}
                                        <tr>
                                            <td>
                                                <strong>{{ reservation.date|date('d/m/Y') }}</strong>
                                                {% if reservation.date|date('Y-m-d') == "now"|date('Y-m-d') %}
                                                    <span class="badge bg-warning ms-1">Aujourd'hui</span>
                                                {% endif %}
                                            </td>
                                            <!-- CORRECTION ICI : Utilisez reservation.date au lieu de reservation.heure -->
                                            <td>{{ reservation.date|date('H:i') }}</td>
                                            <td>
                                                <span class="badge bg-info">
                                                    Table {{ reservation.restaurantTable.numero }}
                                                </span>
                                                <small class="text-muted d-block">({{ reservation.restaurantTable.capacite }} pers.)</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">{{ reservation.nbPersonnes }} pers.</span>
                                            </td>
                                            <td>
                                                {% if reservation.status == 'en_attente' %}
                                                    <span class="badge bg-warning">En attente</span>
                                                {% elseif reservation.status == 'confirmée' %}
                                                    <span class="badge bg-success">Confirmée</span>
                                                {% elseif reservation.status == 'honorée' %}
                                                    <span class="badge bg-primary">Honorée</span>
                                                {% elseif reservation.status == 'annulée' %}
                                                    <span class="badge bg-danger">Annulée</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if reservation.status == 'en_attente' or reservation.status == 'confirmée' %}
                                                    <form method="post" action="{{ path('app_client_reservation_cancel', {'id': reservation.id}) }}" class="d-inline">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ reservation.id) }}">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Êtes-vous sûr de vouloir annuler cette réservation ?')">
                                                            <i class="fas fa-times me-1"></i> Annuler
                                                        </button>
                                                    </form>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center py-4">
                            <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                            <p class="text-muted">Aucune réservation à venir</p>
                            <a href="{{ path('app_client_reservation_new') }}" class="btn btn-primary">
                                <i class="fas fa-plus-circle me-2"></i> Réserver une table
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Réservations passées -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-history me-2"></i>
                        Historique des réservations
                    </h5>
                </div>
                <div class="card-body">
                    {% set pastReservations = reservations|filter(r => r.date < date('today') or r.status in ['honorée', 'annulée']) %}
                    
                    {% if pastReservations|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Heure</th>
                                        <th>Table</th>
                                        <th>Personnes</th>
                                        <th>Statut</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for reservation in pastReservations %}
                                        <tr>
                                            <td>{{ reservation.date|date('d/m/Y') }}</td>
                                            <!-- CORRECTION ICI AUSSI -->
                                            <td>{{ reservation.date|date('H:i') }}</td>
                                            <td>Table {{ reservation.restaurantTable.numero }}</td>
                                            <td>{{ reservation.nbPersonnes }} pers.</td>
                                            <td>
                                                {% if reservation.status == 'honorée' %}
                                                    <span class="badge bg-primary">Honorée</span>
                                                {% elseif reservation.status == 'annulée' %}
                                                    <span class="badge bg-danger">Annulée</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">{{ reservation.status }}</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center py-4">
                            <i class="fas fa-history fa-3x text-muted mb-3"></i>
                            <p class="text-muted">Aucun historique de réservations</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </main>
    </div>
</div>

<style>
.sidebar {
    background-color: #2c3e50;
    min-height: calc(100vh - 56px);
    padding-top: 1rem;
}
.sidebar .nav-link {
    color: #ecf0f1;
    padding: 0.75rem 1rem;
    border-left: 3px solid transparent;
    transition: all 0.3s;
}
.sidebar .nav-link:hover {
    color: #fff;
    background-color: rgba(255, 255, 255, 0.1);
    border-left-color: #3498db;
}
.sidebar .nav-link.active {
    color: #fff;
    background-color: rgba(52, 152, 219, 0.2);
    border-left-color: #3498db;
}
.content-area {
    background-color: #f8f9fa;
    min-height: calc(100vh - 56px);
}
.badge {
    font-size: 0.75em;
    padding: 0.35em 0.65em;
}
.table th {
    font-weight: 600;
    border-top: none;
}
</style>
{% endblock %}