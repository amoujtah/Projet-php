{% extends "base.html.twig" %}

{% block title %}{{ plat.nom }} - Le Bistrot Français{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2 sidebar">
            <nav class="nav flex-column">
                <h6 class="px-3 mb-3 text-uppercase text-light opacity-75">Espace Client</h6>
                
                <a class="nav-link" href="{{ path('app_client_dashboard') }}">
                    <i class="fas fa-tachometer-alt"></i> Tableau de bord
                </a>
                
                <a class="nav-link" href="{{ path('app_client_reservations') }}">
                    <i class="fas fa-calendar-check"></i> Mes réservations
                </a>
                
                <a class="nav-link" href="{{ path('app_client_reservation_new') }}">
                    <i class="fas fa-plus-circle"></i> Nouvelle réservation
                </a>
                
                <a class="nav-link active" href="{{ path('app_client_carte') }}">
                    <i class="fas fa-utensils"></i> Notre carte
                </a>
                
                <a class="nav-link" href="{{ path('app_client_profile') }}">
                    <i class="fas fa-user-cog"></i> Mon profil
                </a>
            </nav>
        </div>
        
        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 content-area">
            <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2 mb-0">
                    <i class="fas fa-utensils me-2"></i>
                    {{ plat.nom }}
                </h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="{{ path('app_client_carte') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i> Retour à la carte
                    </a>
                </div>
            </div>

            <div class="row">
                <!-- Image du plat (optionnelle) -->
                <div class="col-md-5 mb-4">
                    <div class="card">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <div class="avatar avatar-xxl mb-3 mx-auto">
                                    <div class="avatar-title bg-light text-primary rounded-circle">
                                        <i class="fas fa-utensils fs-1"></i>
                                    </div>
                                </div>
                                <h4 class="text-primary">{{ plat.nom }}</h4>
                                <h3 class="text-success">{{ plat.prix|default(0) }}€</h3>
                            </div>
                            
                            <div class="mb-3">
                                {% if plat.categorie is defined and plat.categorie %}
                                    <span class="badge bg-secondary fs-6">{{ plat.categorie }}</span>
                                {% endif %}
                            </div>
                            
                            {% if plat.tempsPreparation is defined and plat.tempsPreparation %}
                                <div class="alert alert-info">
                                    <i class="fas fa-clock me-2"></i>
                                    <strong>Temps de préparation :</strong> {{ plat.tempsPreparation }} minutes
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
                
                <!-- Détails du plat -->
                <div class="col-md-7 mb-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Description</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text">{{ plat.description|default('Pas de description disponible.') }}</p>
                        </div>
                    </div>
                    
                    <!-- Informations complémentaires -->
                    <div class="card mt-4">
                        <div class="card-header">
                            <h5 class="mb-0">Informations</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <p><strong><i class="fas fa-tag me-2"></i> Catégorie :</strong><br>
                                        {{ plat.categorie|default('Non spécifiée') }}
                                    </p>
                                    <p><strong><i class="fas fa-money-bill-wave me-2"></i> Prix :</strong><br>
                                        {{ plat.prix|default(0) }}€
                                    </p>
                                </div>
                                <div class="col-md-6">
                                    {% if plat.tempsPreparation is defined and plat.tempsPreparation %}
                                        <p><strong><i class="fas fa-clock me-2"></i> Préparation :</strong><br>
                                            {{ plat.tempsPreparation }} minutes
                                        </p>
                                    {% endif %}
                                    {% if plat.createdAt is defined and plat.createdAt %}
                                        <p><strong><i class="fas fa-calendar-plus me-2"></i> Ajouté le :</strong><br>
                                            {{ plat.createdAt|date('d/m/Y') }}
                                        </p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Actions -->
                    <div class="card mt-4">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <a href="{{ path('app_client_carte') }}" class="btn btn-outline-secondary">
                                    <i class="fas fa-arrow-left me-1"></i> Retour à la carte
                                </a>
                                <a href="{{ path('app_client_reservation_new') }}" class="btn btn-primary">
                                    <i class="fas fa-calendar-plus me-1"></i> Réserver une table
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Suggestions (optionnel) -->
            <div class="row mt-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Vous pourriez aussi aimer</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                {% set suggestions = plats_similaires|default([]) %}
                                {% if suggestions|length > 0 %}
                                    {% for suggestion in suggestions|slice(0, 3) %}
                                        <div class="col-md-4">
                                            <div class="card h-100 border">
                                                <div class="card-body text-center">
                                                    <h6 class="card-title">{{ suggestion.nom }}</h6>
                                                    <p class="text-primary fw-bold">{{ suggestion.prix|default(0) }}€</p>
                                                    <a href="{{ path('app_client_plat_show', {'id': suggestion.id}) }}" 
                                                       class="btn btn-sm btn-outline-primary">
                                                        Voir détails
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    {% endfor %}
                                {% else %}
                                    <div class="col-12 text-center">
                                        <p class="text-muted">Découvrez tous nos plats dans notre carte.</p>
                                        <a href="{{ path('app_client_carte') }}" class="btn btn-outline-primary">
                                            <i class="fas fa-book-open me-1"></i> Voir toute la carte
                                        </a>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<style>
.avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
}
.avatar-xxl {
    width: 120px;
    height: 120px;
}
.avatar-title {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
}
.card {
    border: none;
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
}
.sidebar {
    background-color: #2c3e50;
    min-height: calc(100vh - 56px);
    padding-top: 1rem;
}
.sidebar .nav-link {
    color: #ecf0f1;
    padding: 0.75rem 1rem;
    border-left: 3px solid transparent;
    transition: all 0.3s;
}
.sidebar .nav-link:hover {
    color: #fff;
    background-color: rgba(255, 255, 255, 0.1);
    border-left-color: #3498db;
}
.sidebar .nav-link.active {
    color: #fff;
    background-color: rgba(52, 152, 219, 0.2);
    border-left-color: #3498db;
}
.content-area {
    background-color: #f8f9fa;
    min-height: calc(100vh - 56px);
}
</style>
{% endblock %}