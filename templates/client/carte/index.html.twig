{% extends "base.html.twig" %}

{% block title %}Notre carte - Le Bistrot Français{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2 sidebar">
            <nav class="nav flex-column">
                <h6 class="px-3 mb-3 text-uppercase text-light opacity-75">Espace Client</h6>
                
                <a class="nav-link" href="{{ path('app_client_dashboard') }}">
                    <i class="fas fa-tachometer-alt"></i> Tableau de bord
                </a>
                
                <a class="nav-link" href="{{ path('app_client_reservations') }}">
                    <i class="fas fa-calendar-check"></i> Mes réservations
                </a>
                
                <a class="nav-link" href="{{ path('app_client_reservation_new') }}">
                    <i class="fas fa-plus-circle"></i> Nouvelle réservation
                </a>
                
                <a class="nav-link active" href="{{ path('app_client_carte') }}">
                    <i class="fas fa-utensils"></i> Notre carte
                </a>
                
                <a class="nav-link" href="{{ path('app_client_profile') }}">
                    <i class="fas fa-user-cog"></i> Mon profil
                </a>
            </nav>
        </div>
        
        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 content-area">
            <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2 mb-0">
                    <i class="fas fa-utensils me-2"></i>
                    Notre carte
                </h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="{{ path('app_client_reservation_new') }}" class="btn btn-primary">
                        <i class="fas fa-calendar-plus me-2"></i> Réserver une table
                    </a>
                </div>
            </div>

            <!-- Filtres simplifiés -->
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Catégorie</label>
                            <select class="form-select" id="categoryFilter">
                                <option value="all">Toutes les catégories</option>
                                <option value="entree">Entrées</option>
                                <option value="plat">Plats principaux</option>
                                <option value="dessert">Desserts</option>
                                <option value="boisson">Boissons</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Prix maximum</label>
                            <select class="form-select" id="priceFilter">
                                <option value="999">Tous les prix</option>
                                <option value="10">Moins de 10€</option>
                                <option value="20">Moins de 20€</option>
                                <option value="30">Moins de 30€</option>
                                <option value="40">Moins de 40€</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Recherche</label>
                            <input type="text" class="form-control" id="searchFilter" placeholder="Rechercher un plat...">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Plats uniquement -->
            <div class="row" id="platsContainer">
                {% for plat in plats %}
                    <div class="col-md-6 col-lg-4 mb-4 plat-item" 
                         data-category="{{ plat.categorie|default('') }}" 
                         data-price="{{ plat.prix|default(0) }}">
                        <div class="card h-100 border shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title mb-0 text-primary">{{ plat.nom }}</h5>
                                    <span class="badge bg-primary fs-6">{{ plat.prix|default(0) }}€</span>
                                </div>
                                
                                <p class="card-text text-muted mb-3">
                                    {{ plat.description|default('')|length > 100 ? plat.description|default('')|slice(0, 100) ~ '...' : plat.description|default('') }}
                                </p>
                                
                                <div class="mb-3">
                                    {% if plat.categorie is defined and plat.categorie %}
                                        <span class="badge bg-secondary">{{ plat.categorie }}</span>
                                    {% endif %}
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center">
                                    <a href="{{ path('app_client_plat_show', {'id': plat.id}) }}" 
                                       class="btn btn-primary btn-sm">
                                        <i class="fas fa-info-circle me-1"></i> Voir détails
                                    </a>
                                    {% if plat.tempsPreparation is defined and plat.tempsPreparation %}
                                        <small class="text-muted">
                                            <i class="fas fa-clock me-1"></i>
                                            {{ plat.tempsPreparation }} min
                                        </small>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12 text-center py-5">
                        <div class="alert alert-info">
                            <i class="fas fa-utensils fa-3x text-info mb-3"></i>
                            <h5 class="text-info">Aucun plat disponible pour le moment</h5>
                            <p class="text-muted mb-3">Notre carte est en cours de mise à jour.</p>
                            <a href="{{ path('app_client_reservation_new') }}" class="btn btn-primary">
                                <i class="fas fa-calendar-plus me-2"></i> Réserver une table
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
            
            <!-- Pagination (optionnelle) -->
            {% if plats|length > 12 %}
                <nav aria-label="Pagination des plats" class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item disabled">
                            <a class="page-link" href="#" tabindex="-1">Précédent</a>
                        </li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item">
                            <a class="page-link" href="#">Suivant</a>
                        </li>
                    </ul>
                </nav>
            {% endif %}
        </main>
    </div>
</div>

<style>
.card {
    transition: transform 0.2s, box-shadow 0.2s;
    border: 1px solid #e9ecef;
}
.card:hover {
    transform: translateY(-5px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}
.badge {
    font-size: 0.8em;
}
.content-area {
    background-color: #f8f9fa;
    min-height: calc(100vh - 56px);
}
.sidebar {
    background-color: #2c3e50;
    min-height: calc(100vh - 56px);
    padding-top: 1rem;
}
.sidebar .nav-link {
    color: #ecf0f1;
    padding: 0.75rem 1rem;
    border-left: 3px solid transparent;
    transition: all 0.3s;
}
.sidebar .nav-link:hover {
    color: #fff;
    background-color: rgba(255, 255, 255, 0.1);
    border-left-color: #3498db;
}
.sidebar .nav-link.active {
    color: #fff;
    background-color: rgba(52, 152, 219, 0.2);
    border-left-color: #3498db;
}
.btn-primary {
    background-color: #3498db;
    border-color: #3498db;
}
.btn-primary:hover {
    background-color: #2980b9;
    border-color: #2980b9;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Filtres
    const categoryFilter = document.getElementById('categoryFilter');
    const priceFilter = document.getElementById('priceFilter');
    const searchFilter = document.getElementById('searchFilter');
    const platItems = document.querySelectorAll('.plat-item');
    
    function applyFilters() {
        const categoryValue = categoryFilter.value;
        const priceValue = parseFloat(priceFilter.value);
        const searchValue = searchFilter.value.toLowerCase();
        
        platItems.forEach(item => {
            const category = item.getAttribute('data-category').toLowerCase();
            const price = parseFloat(item.getAttribute('data-price'));
            const text = item.textContent.toLowerCase();
            
            let show = true;
            
            // Filtre par catégorie
            if (categoryValue !== 'all' && category !== categoryValue) {
                show = false;
            }
            
            // Filtre par prix
            if (price > priceValue) {
                show = false;
            }
            
            // Filtre par recherche
            if (searchValue && !text.includes(searchValue)) {
                show = false;
            }
            
            item.style.display = show ? 'block' : 'none';
        });
        
        // Vérifier si aucun plat n'est visible
        const visibleItems = Array.from(platItems).filter(item => item.style.display !== 'none');
        const noResults = document.getElementById('noResults');
        
        if (visibleItems.length === 0) {
            if (!noResults) {
                const noResultsDiv = document.createElement('div');
                noResultsDiv.id = 'noResults';
                noResultsDiv.className = 'col-12 text-center py-5';
                noResultsDiv.innerHTML = `
                    <div class="alert alert-warning">
                        <i class="fas fa-search fa-3x text-warning mb-3"></i>
                        <h5 class="text-warning">Aucun plat ne correspond à votre recherche</h5>
                        <p class="text-muted mb-3">Essayez de modifier vos critères de recherche.</p>
                        <button class="btn btn-outline-warning" onclick="resetFilters()">
                            <i class="fas fa-redo me-2"></i> Réinitialiser les filtres
                        </button>
                    </div>
                `;
                document.getElementById('platsContainer').appendChild(noResultsDiv);
            }
        } else if (noResults) {
            noResults.remove();
        }
    }
    
    // Fonction pour réinitialiser les filtres
    window.resetFilters = function() {
        categoryFilter.value = 'all';
        priceFilter.value = '999';
        searchFilter.value = '';
        applyFilters();
    };
    
    // Appliquer les filtres automatiquement
    if (categoryFilter) categoryFilter.addEventListener('change', applyFilters);
    if (priceFilter) priceFilter.addEventListener('change', applyFilters);
    if (searchFilter) searchFilter.addEventListener('input', applyFilters);
    
    // Appliquer les filtres au chargement
    applyFilters();
});
</script>
{% endblock %}