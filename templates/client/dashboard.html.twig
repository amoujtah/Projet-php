{% extends "base.html.twig" %}

{% block title %}Tableau de bord Client - Le Bistrot Français{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2 sidebar">
            <nav class="nav flex-column">
                <h6 class="px-3 mb-3 text-uppercase text-light opacity-75">Espace Client</h6>
                
                <a class="nav-link active" href="{{ path('app_client_dashboard') }}">
                    <i class="fas fa-tachometer-alt"></i> Tableau de bord
                </a>
                
                <a class="nav-link" href="{{ path('app_client_reservations') }}">
                    <i class="fas fa-calendar-check"></i> Mes réservations
                </a>
                
                <a class="nav-link" href="{{ path('app_client_reservation_new') }}">
                    <i class="fas fa-plus-circle"></i> Nouvelle réservation
                </a>
                
                <a class="nav-link" href="{{ path('app_client_carte') }}">
                    <i class="fas fa-utensils"></i> Notre carte
                </a>
                
                <a class="nav-link" href="{{ path('app_client_profile') }}">
                    <i class="fas fa-user-cog"></i> Mon profil
                </a>
            </nav>
        </div>
        
        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 content-area">
            <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2 mb-0">
                    <i class="fas fa-tachometer-alt me-2"></i>
                    Tableau de bord
                </h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="{{ path('app_client_reservation_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus-circle me-2"></i> Nouvelle réservation
                    </a>
                </div>
            </div>

            <!-- Statistiques -->
            <div class="row mb-4">
                <div class="col-md-4 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="me-3">
                                    <div class="avatar-sm rounded-circle bg-primary bg-opacity-10 p-3">
                                        <i class="fas fa-calendar-alt text-primary fs-4"></i>
                                    </div>
                                </div>
                                <div>
                                    <h5 class="mb-1">{{ stats.total_reservations|default(0) }}</h5>
                                    <p class="text-muted mb-0">Total réservations</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="me-3">
                                    <div class="avatar-sm rounded-circle bg-success bg-opacity-10 p-3">
                                        <i class="fas fa-clock text-success fs-4"></i>
                                    </div>
                                </div>
                                <div>
                                    <h5 class="mb-1">{{ stats.prochaines_reservations|default(0) }}</h5>
                                    <p class="text-muted mb-0">À venir</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="me-3">
                                    <div class="avatar-sm rounded-circle bg-info bg-opacity-10 p-3">
                                        <i class="fas fa-history text-info fs-4"></i>
                                    </div>
                                </div>
                                <div>
                                    <h5 class="mb-1">{{ stats.reservations_passees|default(0) }}</h5>
                                    <p class="text-muted mb-0">Passées</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mes prochaines réservations -->
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Mes prochaines réservations</h5>
                            <a href="{{ path('app_client_reservations') }}" class="btn btn-sm btn-outline-primary">
                                Voir toutes
                            </a>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Date & Heure</th>
                                            <th>Table</th>
                                            <th>Personnes</th>
                                            <th>Statut</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% set upcomingReservations = reservations|filter(r => r.date|date('Y-m-d') >= "now"|date('Y-m-d') and r.status in ['en_attente', 'confirmée']) %}
                                        
                                        {% if upcomingReservations|length > 0 %}
                                            {% for reservation in upcomingReservations %}
                                            <tr>
                                                <td>#{{ reservation.id }}</td>
                                                <td>
                                                    <div>
                                                        <i class="fas fa-calendar me-1"></i>
                                                        {{ reservation.date|date('d/m/Y') }}
                                                    </div>
                                                    <div>
                                                        <i class="fas fa-clock me-1"></i>
                                                        {{ reservation.heure|date('H:i') }}
                                                    </div>
                                                </td>
                                                <td>
                                                    <span class="badge bg-info">
                                                        Table {{ reservation.restaurantTable.numero }}
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="badge bg-secondary">
                                                        {{ reservation.nbPersonnes }} pers.
                                                    </span>
                                                </td>
                                                <td>
                                                    {% if reservation.status == 'confirmée' %}
                                                        <span class="badge bg-success">Confirmée</span>
                                                    {% elseif reservation.status == 'en_attente' %}
                                                        <span class="badge bg-warning">En attente</span>
                                                    {% endif %}
                                                </td>
                                                <td>
                                                    {% if reservation.status == 'en_attente' or reservation.status == 'confirmée' %}
                                                        <form method="POST" action="{{ path('app_client_reservation_cancel', {'id': reservation.id}) }}" 
                                                              onsubmit="return confirm('Voulez-vous vraiment annuler cette réservation ?');"
                                                              class="d-inline">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ reservation.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                <i class="fas fa-times"></i> Annuler
                                                            </button>
                                                        </form>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                            {% endfor %}
                                        {% else %}
                                            <tr>
                                                <td colspan="6" class="text-center py-4">
                                                    <i class="fas fa-calendar-times fa-2x text-muted mb-3"></i>
                                                    <p class="text-muted mb-0">Aucune réservation à venir</p>
                                                    <a href="{{ path('app_client_reservation_new') }}" class="btn btn-primary mt-2">
                                                        <i class="fas fa-plus me-1"></i> Réserver une table
                                                    </a>
                                                </td>
                                            </tr>
                                        {% endif %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Suggestions -->
            <div class="row mt-4">
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Découvrez nos plats</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                {% for plat in popularPlats|slice(0, 3) %}
                                <div class="col-md-4 mb-3">
                                    <div class="card h-100 border">
                                        <div class="card-body text-center">
                                            <div class="mb-3">
                                                <div class="avatar avatar-lg mb-2 mx-auto">
                                                    <div class="avatar-title bg-light text-primary rounded-circle">
                                                        <i class="fas fa-utensils fs-4"></i>
                                                    </div>
                                                </div>
                                                <h6 class="mb-1">{{ plat.nom }}</h6>
                                                <p class="text-primary fw-bold mb-2">{{ plat.prix }}€</p>
                                            </div>
                                            <p class="text-muted small mb-3">
                                                {{ plat.description|length > 80 ? plat.description|slice(0, 80) ~ '...' : plat.description }}
                                            </p>
                                            <a href="{{ path('app_client_plat_show', {'id': plat.id}) }}" 
                                               class="btn btn-sm btn-outline-primary">
                                                Voir détails
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                        <div class="card-footer text-center">
                            <a href="{{ path('app_client_carte') }}" class="btn btn-outline-primary">
                                <i class="fas fa-book-open me-1"></i> Voir toute la carte
                            </a>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Actions rapides</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                <a href="{{ path('app_client_reservation_new') }}" class="btn btn-outline-primary text-start">
                                    <i class="fas fa-plus-circle me-2"></i> Nouvelle réservation
                                </a>
                                <a href="{{ path('app_client_carte') }}" class="btn btn-outline-success text-start">
                                    <i class="fas fa-utensils me-2"></i> Voir la carte
                                </a>
                                <a href="{{ path('app_client_reservations') }}" class="btn btn-outline-warning text-start">
                                    <i class="fas fa-list me-2"></i> Mes réservations
                                </a>
                                <a href="{{ path('app_client_profile') }}" class="btn btn-outline-info text-start">
                                    <i class="fas fa-user-edit me-2"></i> Mon profil
                                </a>
                            </div>
                        </div>
                    </div>
                    
                    <div class="card mt-4">
                        <div class="card-header">
                            <h5 class="mb-0">Informations</h5>
                        </div>
                        <div class="card-body">
                            <p class="mb-2">
                                <i class="fas fa-user me-2"></i>
                                <strong>{{ user.nom }}</strong>
                            </p>
                            <p class="mb-2">
                                <i class="fas fa-envelope me-2"></i>
                                {{ user.email }}
                            </p>
                            {% if user.phone %}
                            <p class="mb-0">
                                <i class="fas fa-phone me-2"></i>
                                {{ user.phone }}
                            </p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<style>
.avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
}
.avatar-lg {
    width: 60px;
    height: 60px;
}
.avatar-sm {
    width: 50px;
    height: 50px;
}
.avatar-title {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
}
</style>
{% endblock %}