{% extends "base.html.twig" %}

{% block title %}Toutes les réservations - Serveur{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="fas fa-calendar-alt me-2"></i>
            Toutes les réservations
        </h1>
        <div class="btn-group">
            <a href="{{ path('app_serveur_dashboard') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-1"></i> Retour
            </a>
            <a href="{{ path('app_serveur_reservation_new') }}" class="btn btn-primary ms-2">
                <i class="fas fa-plus me-1"></i> Nouvelle réservation
            </a>
        </div>
    </div>

    <!-- Filtres -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="GET" action="" class="row g-3">
                <div class="col-md-3">
                    <label for="date" class="form-label">Date</label>
                    <input type="date" class="form-control" id="date" name="date" 
                           value="{{ app.request.query.get('date') }}">
                </div>
                <div class="col-md-3">
                    <label for="status" class="form-label">Statut</label>
                    <select class="form-select" id="status" name="status">
                        <option value="">Tous</option>
                        <option value="en_attente" {% if app.request.query.get('status') == 'en_attente' %}selected{% endif %}>En attente</option>
                        <option value="confirmée" {% if app.request.query.get('status') == 'confirmée' %}selected{% endif %}>Confirmée</option>
                        <option value="honorée" {% if app.request.query.get('status') == 'honorée' %}selected{% endif %}>Honorée</option>
                        <option value="annulée" {% if app.request.query.get('status') == 'annulée' %}selected{% endif %}>Annulée</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="client" class="form-label">Client</label>
                    <input type="text" class="form-control" id="client" name="client" 
                           value="{{ app.request.query.get('client') }}" 
                           placeholder="Nom du client">
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-filter me-1"></i> Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Liste des réservations -->
    <div class="card">
        <div class="card-body">
            {% if reservations|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Date et Heure</th>
                                <th>Client</th>
                                <th>Table</th>
                                <th>Personnes</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for reservation in reservations %}
                                <tr class="{% if reservation.status == 'annulée' %}table-danger{% elseif reservation.status == 'honorée' %}table-success{% endif %}">
                                    <td>
                                        {{ reservation.date|date('d/m/Y H:i') }}
                                    </td>
                                    <td>{{ reservation.client.nom }}</td>
                                    <td>Table {{ reservation.restaurantTable.numero }}</td>
                                    <td>{{ reservation.nbPersonnes }}</td>
                                    <td>
                                        {% if reservation.status == 'confirmée' %}
                                            <span class="badge bg-success">Confirmée</span>
                                        {% elseif reservation.status == 'en_attente' %}
                                            <span class="badge bg-warning">En attente</span>
                                        {% elseif reservation.status == 'annulée' %}
                                            <span class="badge bg-danger">Annulée</span>
                                        {% elseif reservation.status == 'honorée' %}
                                            <span class="badge bg-info">Honorée</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            {% if reservation.status == 'en_attente' %}
                                                <form method="POST" action="{{ path('app_serveur_reservation_confirm', {'id': reservation.id}) }}">
                                                    <button type="submit" class="btn btn-success" title="Confirmer">
                                                        <i class="fas fa-check"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                            
                                            {% if reservation.status == 'confirmée' %}
                                                <form method="POST" action="{{ path('app_serveur_reservation_honor', {'id': reservation.id}) }}">
                                                    <button type="submit" class="btn btn-info" title="Marquer comme honorée">
                                                        <i class="fas fa-check-double"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                            
                                            {% if reservation.status in ['en_attente', 'confirmée'] %}
                                                <form method="POST" action="{{ path('app_serveur_reservation_cancel', {'id': reservation.id}) }}">
                                                    <button type="submit" class="btn btn-danger" title="Annuler" 
                                                            onclick="return confirm('Annuler cette réservation ?')">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                            
                                            <button type="button" class="btn btn-secondary" 
                                                    data-bs-toggle="modal" 
                                                    data-bs-target="#detailsModal{{ reservation.id }}"
                                                    title="Détails">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                        </div>
                                        
                                        <!-- Modal Détails -->
                                        <div class="modal fade" id="detailsModal{{ reservation.id }}" tabindex="-1">
                                            <div class="modal-dialog">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Détails de la réservation</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <div class="row">
                                                            <div class="col-6">
                                                                <p><strong>Date :</strong> {{ reservation.date|date('d/m/Y') }}</p>
                                                                <p><strong>Heure :</strong> {{ reservation.date|date('H:i') }}</p>
                                                                <p><strong>Personnes :</strong> {{ reservation.nbPersonnes }}</p>
                                                            </div>
                                                            <div class="col-6">
                                                                <p><strong>Table :</strong> {{ reservation.restaurantTable.numero }}</p>
                                                                <p><strong>Capacité :</strong> {{ reservation.restaurantTable.capacite }}</p>
                                                                <p><strong>Statut :</strong> 
                                                                    {% if reservation.status == 'confirmée' %}
                                                                        <span class="badge bg-success">Confirmée</span>
                                                                    {% elseif reservation.status == 'en_attente' %}
                                                                        <span class="badge bg-warning">En attente</span>
                                                                    {% elseif reservation.status == 'annulée' %}
                                                                        <span class="badge bg-danger">Annulée</span>
                                                                    {% elseif reservation.status == 'honorée' %}
                                                                        <span class="badge bg-info">Honorée</span>
                                                                    {% endif %}
                                                                </p>
                                                            </div>
                                                        </div>
                                                        <hr>
                                                        <h6>Client</h6>
                                                        <p><strong>Nom :</strong> {{ reservation.client.nom }}</p>
                                                        <p><strong>Email :</strong> {{ reservation.client.email }}</p>
                                                        {% if reservation.client.phone %}
                                                            <p><strong>Téléphone :</strong> {{ reservation.client.phone }}</p>
                                                        {% endif %}
                                                        <p><strong>Membre depuis :</strong> {{ reservation.client.createdAt|date('d/m/Y') }}</p>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-5">
                    <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">Aucune réservation trouvée</h4>
                    <p class="text-muted">Essayez de modifier vos filtres ou créez une nouvelle réservation.</p>
                    <a href="{{ path('app_serveur_reservation_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i> Créer une réservation
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}