{# templates/serveur/carte/_plat_card.html.twig #}
<div class="col-md-4 col-lg-3">
    <div class="card h-100 shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <div class="d-flex justify-content-between align-items-center">
                <h6 class="mb-0">{{ plat.nom }}</h6>
                <span class="badge {% if plat.disponible %}bg-success{% else %}bg-danger{% endif %}">
                    {% if plat.disponible %}Disponible{% else %}Indisponible{% endif %}
                </span>
            </div>
        </div>
        <div class="card-body">
            <p class="card-text small text-muted">{{ plat.description|default('') }}</p>
            <h5 class="text-primary">{{ plat.prix }} €</h5>
            <p class="mb-1">
                <small class="text-muted">
                    <i class="fas fa-tag"></i> {{ plat.categorie|capitalize }}
                </small>
            </p>
        </div>
        <div class="card-footer bg-transparent border-top-0">
            <div class="d-flex justify-content-between">
                <!-- Bouton Modifier -->
                <button type="button" class="btn btn-sm btn-outline-primary" 
                        data-bs-toggle="modal" 
                        data-bs-target="#editPlatModal{{ plat.id }}">
                    <i class="fas fa-edit"></i>
                </button>
                
                <!-- Bouton Supprimer -->
                <form method="POST" action="{{ path('app_serveur_plat_delete', {'id': plat.id}) }}"
                      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce plat ?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="fas fa-trash"></i>
                    </button>
                </form>
                
                <!-- Bouton Changer Disponibilité -->
                <form method="POST" action="{{ path('app_serveur_plat_toggle', {'id': plat.id}) }}">
                    <button type="submit" class="btn btn-sm {% if plat.disponible %}btn-outline-warning{% else %}btn-outline-success{% endif %}">
                        <i class="fas {% if plat.disponible %}fa-eye-slash{% else %}fa-eye{% endif %}"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
    
    <!-- Modal de modification (à inclure une fois par plat) -->
    <div class="modal fade" id="editPlatModal{{ plat.id }}" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="POST" action="{{ path('app_serveur_plat_edit', {'id': plat.id}) }}">
                    <div class="modal-header">
                        <h5 class="modal-title">Modifier le plat</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="nom{{ plat.id }}" class="form-label">Nom</label>
                            <input type="text" class="form-control" id="nom{{ plat.id }}" 
                                   name="nom" value="{{ plat.nom }}" required>
                        </div>
                        <div class="mb-3">
                            <label for="categorie{{ plat.id }}" class="form-label">Catégorie</label>
                            <select class="form-select" id="categorie{{ plat.id }}" name="categorie" required>
                                <option value="entree" {% if plat.categorie == 'entree' %}selected{% endif %}>Entrée</option>
                                <option value="plat" {% if plat.categorie == 'plat' %}selected{% endif %}>Plat principal</option>
                                <option value="dessert" {% if plat.categorie == 'dessert' %}selected{% endif %}>Dessert</option>
                                <option value="boisson" {% if plat.categorie == 'boisson' %}selected{% endif %}>Boisson</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="description{{ plat.id }}" class="form-label">Description</label>
                            <textarea class="form-control" id="description{{ plat.id }}" 
                                      name="description" rows="3">{{ plat.description|default('') }}</textarea>
                        </div>
                        <div class="mb-3">
                            <label for="prix{{ plat.id }}" class="form-label">Prix (€)</label>
                            <input type="number" step="0.01" class="form-control" id="prix{{ plat.id }}" 
                                   name="prix" value="{{ plat.prix }}" required>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="disponible{{ plat.id }}" 
                                       name="disponible" value="1" {% if plat.disponible %}checked{% endif %}>
                                <label class="form-check-label" for="disponible{{ plat.id }}">Disponible</label>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btn btn-primary">Enregistrer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>