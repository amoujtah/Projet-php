{% extends "base.html.twig" %}

{% block title %}Nouvelle table - Administration{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2 sidebar">
            <nav class="nav flex-column">
                <h6 class="px-3 mb-3 text-uppercase text-light opacity-75">Administration</h6>
                
                <a class="nav-link" href="{{ path('app_admin_dashboard') }}">
                    <i class="fas fa-tachometer-alt"></i> Tableau de bord
                </a>
                
                <a class="nav-link active" href="{{ path('app_admin_tables') }}">
                    <i class="fas fa-chair"></i> Gestion des tables
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_plats') }}">
                    <i class="fas fa-utensils"></i> Gestion des plats
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_menus') }}">
                    <i class="fas fa-clipboard-list"></i> Gestion des menus
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_users') }}">
                    <i class="fas fa-users"></i> Gestion des utilisateurs
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_reservations') }}">
                    <i class="fas fa-calendar-check"></i> Réservations
                </a>
            </nav>
        </div>
        
        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 content-area">
            <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2 mb-0">
                    <i class="fas fa-plus-circle me-2"></i>
                    Créer une nouvelle table
                </h1>
                <a href="{{ path('app_admin_tables') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Retour à la liste
                </a>
            </div>
            
            <div class="row">
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-body">
                            {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    {{ form_label(form.numero, 'Numéro de table', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                    {{ form_widget(form.numero, {'attr': {'class': 'form-control', 'placeholder': 'Ex: 1, 2, 3...'}}) }}
                                    <div class="invalid-feedback">
                                        Veuillez saisir un numéro de table.
                                    </div>
                                </div>
                                
                                <div class="col-md-6 mb-3">
                                    {{ form_label(form.capacite, 'Capacité', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                    {{ form_widget(form.capacite, {'attr': {'class': 'form-control', 'placeholder': 'Ex: 2, 4, 6...'}}) }}
                                    <div class="invalid-feedback">
                                        Veuillez saisir une capacité.
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    {{ form_widget(form.status, {'attr': {'class': 'form-check-input', 'checked': 'checked'}}) }}
                                    {{ form_label(form.status, 'Table disponible', {'label_attr': {'class': 'form-check-label fw-bold'}}) }}
                                </div>
                                <small class="form-text text-muted">
                                    Désactivez si la table est en réparation ou indisponible
                                </small>
                            </div>
                            
                            <div class="d-flex justify-content-between mt-4">
                                <a href="{{ path('app_admin_tables') }}" class="btn btn-outline-secondary">
                                    <i class="fas fa-times me-2"></i>Annuler
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-2"></i>Créer la table
                                </button>
                            </div>
                            
                            {{ form_end(form) }}
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="fas fa-lightbulb me-2"></i>Conseils</h6>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <h6><i class="fas fa-hashtag me-2"></i>Numérotation</h6>
                                <p class="text-muted small">
                                    Utilisez une numérotation logique (1, 2, 3...) pour faciliter le service.
                                </p>
                            </div>
                            
                            <div class="mb-3">
                                <h6><i class="fas fa-users me-2"></i>Capacité</h6>
                                <p class="text-muted small">
                                    Prévoyez des tables de différentes capacités pour accommoder tous les groupes.
                                </p>
                            </div>
                            
                            <div class="mb-3">
                                <h6><i class="fas fa-cog me-2"></i>Disponibilité</h6>
                                <p class="text-muted small">
                                    Désactivez temporairement les tables en réparation ou réservées à des événements.
                                </p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Statistiques rapides -->
                    <div class="card mt-4">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Statistiques</h6>
                        </div>
                        <div class="card-body">
                            <div class="text-center py-3">
                                {% if tablesCount is defined %}
                                <h3 class="mb-0" style="color: var(--primary-color);">{{ tablesCount + 1 }}</h3>
                                <p class="text-muted mb-0">Nombre total de tables</p>
                                <small class="text-muted">(après création)</small>
                                {% else %}
                                <h3 class="mb-0" style="color: var(--primary-color);">Nouvelle</h3>
                                <p class="text-muted mb-0">Table en création</p>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<script>
// Validation du formulaire
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('form');
    
    form.addEventListener('submit', function(event) {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
        }
        form.classList.add('was-validated');
    }, false);
});
</script>
{% endblock %}