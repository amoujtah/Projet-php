{% extends "base.html.twig" %}

{% block title %}Gestion des tables - Le Bistrot Français{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2 sidebar">
            <nav class="nav flex-column">
                <h6 class="px-3 mb-3 text-uppercase text-light opacity-75">Administration</h6>
                
                <a class="nav-link" href="{{ path('app_admin_dashboard') }}">
                    <i class="fas fa-tachometer-alt"></i> Tableau de bord
                </a>
                
                <a class="nav-link active" href="{{ path('app_admin_tables') }}">
                    <i class="fas fa-chair"></i> Gestion des tables
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_plats') }}">
                    <i class="fas fa-utensils"></i> Gestion des plats
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_menus') }}">
                    <i class="fas fa-clipboard-list"></i> Gestion des menus
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_users') }}">
                    <i class="fas fa-users"></i> Gestion des utilisateurs
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_reservations') }}">
                    <i class="fas fa-calendar-check"></i> Réservations
                </a>
            </nav>
        </div>
        
        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 content-area">
            <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2 mb-0">
                    <i class="fas fa-chair me-2"></i>
                    Gestion des tables
                </h1>
                <a href="{{ path('app_admin_table_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Nouvelle table
                </a>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}

            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Liste des tables ({{ tables|length }})</h5>
                </div>
                <div class="card-body">
                    {% if tables|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover table-custom">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Numéro</th>
                                    <th>Capacité</th>
                                    <th>Statut</th>
                                    <th>Réservations</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for table in tables %}
                                <tr>
                                    <td>#{{ table.id }}</td>
                                    <td>
                                        <strong>Table {{ table.numero }}</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">
                                            {{ table.capacite }} personnes
                                        </span>
                                    </td>
                                    <td>
                                        {% if table.status %}
                                            <span class="badge bg-success">Disponible</span>
                                        {% else %}
                                            <span class="badge bg-danger">Indisponible</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">
                                            {{ table.reservations|length }} résa
                                        </span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="{{ path('app_admin_table_edit', {'id': table.id}) }}" 
                                               class="btn btn-outline-primary" title="Modifier">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form method="post" 
                                                  action="{{ path('app_admin_table_delete', {'id': table.id}) }}" 
                                                  onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer la Table {{ table.numero }} ?');"
                                                  style="display: inline;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ table.id) }}">
                                                <button type="submit" class="btn btn-outline-danger" title="Supprimer">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-5">
                        <i class="fas fa-chair fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted mb-3">Aucune table disponible</h5>
                        <p class="text-muted mb-4">Créez vos premières tables pour organiser le restaurant</p>
                        <a href="{{ path('app_admin_table_new') }}" class="btn btn-primary">
                            <i class="fas fa-plus me-2"></i>Créer une table
                        </a>
                    </div>
                    {% endif %}
                </div>
            </div>
            
            <!-- Statistiques -->
            <div class="row mt-4">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body text-center">
                            <h3 class="mb-0">{{ tables|length }}</h3>
                            <p class="text-muted mb-0">Tables total</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body text-center">
                            <h3 class="mb-0">
                                {% set totalCapacity = 0 %}
                                {% for table in tables %}
                                    {% set totalCapacity = totalCapacity + table.capacite %}
                                {% endfor %}
                                {{ totalCapacity }}
                            </h3>
                            <p class="text-muted mb-0">Capacité totale</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body text-center">
                            <h3 class="mb-0">
                                {% set availableTables = tables|filter(t => t.status) %}
                                {{ availableTables|length }}
                            </h3>
                            <p class="text-muted mb-0">Tables disponibles</p>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}