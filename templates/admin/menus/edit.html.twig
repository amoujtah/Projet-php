{% extends "base.html.twig" %}

{% block title %}Modifier le menu - Administration{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2 sidebar">
            <nav class="nav flex-column">
                <h6 class="px-3 mb-3 text-uppercase text-light opacity-75">Administration</h6>
                
                <a class="nav-link" href="{{ path('app_admin_dashboard') }}">
                    <i class="fas fa-tachometer-alt"></i> Tableau de bord
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_tables') }}">
                    <i class="fas fa-chair"></i> Gestion des tables
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_plats') }}">
                    <i class="fas fa-utensils"></i> Gestion des plats
                </a>
                
                <a class="nav-link active" href="{{ path('app_admin_menus') }}">
                    <i class="fas fa-clipboard-list"></i> Gestion des menus
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_users') }}">
                    <i class="fas fa-users"></i> Gestion des utilisateurs
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_reservations') }}">
                    <i class="fas fa-calendar-check"></i> Réservations
                </a>
            </nav>
        </div>
        
        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 content-area">
            <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2 mb-0">
                    <i class="fas fa-edit me-2"></i>
                    Modifier le menu : {{ menu.nom }}
                </h1>
                <div>
                    <a href="{{ path('app_admin_menus') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Retour
                    </a>
                    <button type="button" class="btn btn-danger ms-2" data-bs-toggle="modal" data-bs-target="#deleteModal">
                        <i class="fas fa-trash me-2"></i>Supprimer
                    </button>
                </div>
            </div>
            
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
            
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
            
            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                    
                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                {{ form_label(form.nom, 'Nom du menu', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.nom) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.prixTotal, 'Prix total du menu', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                <div class="input-group">
                                    {{ form_widget(form.prixTotal, {'attr': {'class': 'form-control'}}) }}
                                    <span class="input-group-text">€</span>
                                </div>
                                <small class="form-text text-muted">
                                    Le prix total du menu doit être attractif par rapport aux plats individuels
                                </small>
                                {{ form_errors(form.prixTotal) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.plats, 'Plats du menu', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                <div class="form-control" style="height: 300px; overflow-y: auto; padding: 15px;">
                                    <div class="row">
                                        {% if plats is defined and plats %}
                                            {% for plat in plats %}
                                            <div class="col-md-6 mb-2">
                                                <div class="form-check">
                                                    <input class="form-check-input" 
                                                           type="checkbox" 
                                                           value="{{ plat.id }}" 
                                                           id="plat-{{ plat.id }}"
                                                           name="menu[plats][]"
                                                           {% if plat in menu.plats %}checked{% endif %}>
                                                    <label class="form-check-label d-flex justify-content-between w-100" for="plat-{{ plat.id }}">
                                                        <span>
                                                            <strong>{{ plat.nom }}</strong>
                                                            <small class="text-muted ms-2">({{ plat.categorie }})</small>
                                                        </span>
                                                        <span class="text-muted">{{ plat.prix|number_format(2, ',', ' ') }} €</span>
                                                    </label>
                                                </div>
                                            </div>
                                            {% endfor %}
                                        {% else %}
                                            <div class="col-12 text-center py-4">
                                                <i class="fas fa-utensils fa-2x text-muted mb-3"></i>
                                                <p class="text-muted">Aucun plat disponible.</p>
                                                <a href="{{ path('app_admin_plat_new') }}" class="btn btn-sm btn-outline-primary mt-2">
                                                    Créer un plat
                                                </a>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                                {{ form_errors(form.plats) }}
                            </div>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="card sticky-top" style="top: 20px;">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Informations</h6>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <h6>Plats actuels dans ce menu :</h6>
                                        <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                                            {% if menu.plats|length > 0 %}
                                                {% for plat in menu.plats %}
                                                <div class="border-bottom py-2">
                                                    <div class="d-flex justify-content-between">
                                                        <span class="fw-medium">{{ plat.nom }}</span>
                                                        <span class="text-muted">{{ plat.prix|number_format(2, ',', ' ') }} €</span>
                                                    </div>
                                                    <small class="text-muted">{{ plat.categorie }}</small>
                                                </div>
                                                {% endfor %}
                                            {% else %}
                                                <p class="text-muted text-center mb-0 py-2">Aucun plat</p>
                                            {% endif %}
                                        </div>
                                    </div>
                                    
                                    <div class="alert alert-warning">
                                        <small>
                                            <i class="fas fa-exclamation-triangle me-1"></i>
                                            La modification de ce menu affectera toutes les réservations futures.
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-between mt-4">
                        <a href="{{ path('app_admin_menus') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-2"></i>Annuler
                        </a>
                        <div>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Enregistrer les modifications
                            </button>
                        </div>
                    </div>
                    
                    {{ form_end(form) }}
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Modal de suppression -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmer la suppression</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Attention !</strong> Cette action est irréversible.
                </div>
                <p>Êtes-vous sûr de vouloir supprimer le menu <strong>"{{ menu.nom }}"</strong> ?</p>
                <p class="text-muted">Cette action ne peut pas être annulée.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Annuler
                </button>
                <form action="{{ path('app_admin_menu_delete', {'id': menu.id}) }}" method="post" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ menu.id) }}">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Supprimer définitivement
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}