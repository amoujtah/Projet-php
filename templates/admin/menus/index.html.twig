{% extends "base.html.twig" %}

{% block title %}Gestion des menus - Le Bistrot Français{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2 sidebar">
            <nav class="nav flex-column">
                <h6 class="px-3 mb-3 text-uppercase text-light opacity-75">Administration</h6>
                
                <a class="nav-link" href="{{ path('app_admin_dashboard') }}">
                    <i class="fas fa-tachometer-alt"></i> Tableau de bord
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_tables') }}">
                    <i class="fas fa-chair"></i> Gestion des tables
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_plats') }}">
                    <i class="fas fa-utensils"></i> Gestion des plats
                </a>
                
                <a class="nav-link active" href="{{ path('app_admin_menus') }}">
                    <i class="fas fa-clipboard-list"></i> Gestion des menus
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_users') }}">
                    <i class="fas fa-users"></i> Gestion des utilisateurs
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_reservations') }}">
                    <i class="fas fa-calendar-check"></i> Réservations
                </a>
            </nav>
        </div>
        
        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 content-area">
            <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2 mb-0">
                    <i class="fas fa-clipboard-list me-2"></i>
                    Menus
                </h1>
                <a href="{{ path('app_admin_menu_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Nouveau menu
                </a>
            </div>
            
            <div class="row">
                {% for menu in menus %}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title mb-0">{{ menu.nom }}</h5>
                                <span class="fs-5 fw-bold text-primary">
                                    {{ menu.prixTotal|number_format(2, ',', ' ') }} €
                                </span>
                            </div>
                            
                            <div class="card-body">
                                <h6 class="mb-3">
                                    <i class="fas fa-utensils me-2"></i>
                                    Composition ({{ menu.plats|length }} plats)
                                </h6>
                                
                                {% if menu.plats|length > 0 %}
                                    <div class="mb-3">
                                        {% for plat in menu.plats %}
                                            <div class="d-flex align-items-center mb-2">
                                                <!-- SIMPLIFIEZ : RETIREZ L'IMAGE -->
                                                <div class="me-2">
                                                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" 
                                                         style="width: 40px; height: 40px;">
                                                        <i class="fas fa-utensils text-muted"></i>
                                                    </div>
                                                </div>
                                                
                                                <div>
                                                    <div class="fw-medium">{{ plat.nom }}</div>
                                                    <small class="text-muted">{{ plat.prix|number_format(2, ',', ' ') }} € • {{ plat.categorie }}</small>
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <p class="text-muted mb-0">Aucun plat dans ce menu</p>
                                {% endif %}
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                                    {{ menu.plats|length }} plat(s)
                                </small>
                                <div class="btn-group btn-group-sm">
                                    <a href="{{ path('app_admin_menu_edit', {'id': menu.id}) }}" 
                                       class="btn btn-outline-primary">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" 
                                          action="{{ path('app_admin_menu_delete', {'id': menu.id}) }}" 
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce menu ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ menu.id) }}">
                                        <button type="submit" class="btn btn-outline-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                {% else %}
                <div class="col-12">
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted mb-3">Aucun menu disponible</h5>
                            <a href="{{ path('app_admin_menu_new') }}" class="btn btn-primary">
                                <i class="fas fa-plus me-2"></i>Créer votre premier menu
                            </a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </main>
    </div>
</div>
{% endblock %}