{% extends "base.html.twig" %}

{% block title %}Tableau de bord Admin - Le Bistrot Français{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2 sidebar">
            <nav class="nav flex-column">
                <h6 class="px-3 mb-3 text-uppercase text-light opacity-75">Administration</h6>
                
                <a class="nav-link active" href="{{ path('app_admin_dashboard') }}">
                    <i class="fas fa-tachometer-alt"></i> Tableau de bord
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_tables') }}">
                    <i class="fas fa-chair"></i> Gestion des tables
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_plats') }}">
                    <i class="fas fa-utensils"></i> Gestion des plats
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_menus') }}">
                    <i class="fas fa-clipboard-list"></i> Gestion des menus
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_users') }}">
                    <i class="fas fa-users"></i> Gestion des utilisateurs
                </a>
                
                <a class="nav-link" href="{{ path('app_admin_reservations') }}">
                    <i class="fas fa-calendar-check"></i> Réservations
                </a>
            </nav>
        </div>
        
        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 content-area">
            <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2 mb-0">
                    <i class="fas fa-tachometer-alt me-2"></i>
                    Tableau de bord
                </h1>
                <div class="text-muted">
                    <i class="fas fa-calendar-alt me-1"></i>
                    {{ "now"|date("d/m/Y") }}
                </div>
            </div>

            <!-- Statistiques -->
            <div class="row mb-4">
                <div class="col-md-3 mb-3">
                    <div class="card border-start border-primary border-4 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-2">Réservations aujourd'hui</h6>
                                    <h3 class="mb-0">{{ stats.reservations_aujourdhui|default(0) }}</h3>
                                </div>
                                <div class="avatar-sm">
                                    <div class="avatar-title bg-primary bg-opacity-10 rounded">
                                        <i class="fas fa-calendar-day text-primary fs-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-3 mb-3">
                    <div class="card border-start border-success border-4 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-2">Clients</h6>
                                    <h3 class="mb-0">{{ stats.client_count|default(0) }}</h3>
                                </div>
                                <div class="avatar-sm">
                                    <div class="avatar-title bg-success bg-opacity-10 rounded">
                                        <i class="fas fa-users text-success fs-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-3 mb-3">
                    <div class="card border-start border-warning border-4 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-2">En attente</h6>
                                    <h3 class="mb-0">{{ stats.reservations_en_attente|default(0) }}</h3>
                                </div>
                                <div class="avatar-sm">
                                    <div class="avatar-title bg-warning bg-opacity-10 rounded">
                                        <i class="fas fa-clock text-warning fs-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-3 mb-3">
                    <div class="card border-start border-info border-4 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-2">Taux occupation</h6>
                                    <h3 class="mb-0">{{ stats.taux_occupation|default(0) }}%</h3>
                                </div>
                                <div class="avatar-sm">
                                    <div class="avatar-title bg-info bg-opacity-10 rounded">
                                        <i class="fas fa-chart-line text-info fs-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Statistiques secondaires -->
            <div class="row mb-4">
                <div class="col-md-3 mb-3">
                    <div class="card border-start border-secondary border-4 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-2">Administrateurs</h6>
                                    <h3 class="mb-0">{{ stats.admin_count|default(0) }}</h3>
                                </div>
                                <div class="avatar-sm">
                                    <div class="avatar-title bg-secondary bg-opacity-10 rounded">
                                        <i class="fas fa-user-shield text-secondary fs-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-3 mb-3">
                    <div class="card border-start border-purple border-4 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-2">Serveurs</h6>
                                    <h3 class="mb-0">{{ stats.serveur_count|default(0) }}</h3>
                                </div>
                                <div class="avatar-sm">
                                    <div class="avatar-title bg-purple bg-opacity-10 rounded">
                                        <i class="fas fa-user-tie text-purple fs-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-3 mb-3">
                    <div class="card border-start border-danger border-4 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-2">Tables occupées</h6>
                                    <h3 class="mb-0">{{ stats.tables_occupees|default(0) }}</h3>
                                </div>
                                <div class="avatar-sm">
                                    <div class="avatar-title bg-danger bg-opacity-10 rounded">
                                        <i class="fas fa-chair text-danger fs-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-3 mb-3">
                    <div class="card border-start border-teal border-4 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-2">Tables libres</h6>
                                    <h3 class="mb-0">{{ stats.tables_libres|default(0) }}</h3>
                                </div>
                                <div class="avatar-sm">
                                    <div class="avatar-title bg-teal bg-opacity-10 rounded">
                                        <i class="fas fa-chair text-teal fs-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions rapides -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Actions rapides</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-3 mb-3">
                                    <a href="{{ path('app_admin_table_new') }}" class="btn btn-outline-primary w-100 d-flex flex-column align-items-center py-3">
                                        <i class="fas fa-plus-circle fa-2x mb-2"></i>
                                        <span>Ajouter une table</span>
                                    </a>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <a href="{{ path('app_admin_plat_new') }}" class="btn btn-outline-success w-100 d-flex flex-column align-items-center py-3">
                                        <i class="fas fa-utensils fa-2x mb-2"></i>
                                        <span>Ajouter un plat</span>
                                    </a>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <a href="{{ path('app_admin_menu_new') }}" class="btn btn-outline-warning w-100 d-flex flex-column align-items-center py-3">
                                        <i class="fas fa-book fa-2x mb-2"></i>
                                        <span>Créer un menu</span>
                                    </a>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <a href="{{ path('app_admin_user_new') }}" class="btn btn-outline-info w-100 d-flex flex-column align-items-center py-3">
                                        <i class="fas fa-user-plus fa-2x mb-2"></i>
                                        <span>Ajouter un utilisateur</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dernières réservations -->
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Dernières réservations</h5>
                            <a href="{{ path('app_admin_reservations') }}" class="btn btn-sm btn-outline-primary">
                                Voir toutes
                            </a>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Client</th>
                                            <th>Date</th>
                                            <th>Heure</th>
                                            <th>Table</th>
                                            <th>Personnes</th>
                                            <th>Statut</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for reservation in reservations %}
                                        <tr>
                                            <td>#{{ reservation.id }}</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar avatar-sm me-2">
                                                        <div class="avatar-title bg-light text-dark rounded-circle">
                                                            {{ reservation.client.nom|first|upper }}
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <strong>{{ reservation.client.nom }}</strong>
                                                        <br>
                                                        <small class="text-muted">{{ reservation.client.email }}</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>{{ reservation.date|date('d/m/Y') }}</td>
                                            <td>{{ reservation.date|date('H:i') }}</td>
                                            <td>
                                                <span class="badge bg-info">
                                                    Table {{ reservation.restaurantTable.numero }}
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">
                                                    {{ reservation.nbPersonnes }} pers.
                                                </span>
                                            </td>
                                            <td>
                                                {% if reservation.status == 'confirmée' %}
                                                    <span class="badge bg-success">Confirmée</span>
                                                {% elseif reservation.status == 'en_attente' %}
                                                    <span class="badge bg-warning">En attente</span>
                                                {% elseif reservation.status == 'annulée' %}
                                                    <span class="badge bg-danger">Annulée</span>
                                                {% elseif reservation.status == 'honorée' %}
                                                    <span class="badge bg-info">Honorée</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                        {% else %}
                                        <tr>
                                            <td colspan="7" class="text-center py-4">
                                                <i class="fas fa-calendar-times fa-2x text-muted mb-3"></i>
                                                <p class="text-muted mb-0">Aucune réservation</p>
                                            </td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Réservations à venir -->
            {% if upcomingReservations is defined and upcomingReservations|length > 0 %}
            <div class="row mt-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Prochaines réservations</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                {% for reservation in upcomingReservations|slice(0, 4) %}
                                <div class="col-md-3 mb-3">
                                    <div class="card border">
                                        <div class="card-body text-center">
                                            <div class="mb-3">
                                                <div class="avatar avatar-lg mb-2">
                                                    <div class="avatar-title bg-light text-primary rounded-circle">
                                                        <i class="fas fa-calendar-check fs-4"></i>
                                                    </div>
                                                </div>
                                                <h6 class="mb-1">{{ reservation.client.nom }}</h6>
                                                <p class="text-muted small mb-2">{{ reservation.client.email }}</p>
                                            </div>
                                            <div class="border-top pt-3">
                                                <p class="mb-1">
                                                    <i class="fas fa-calendar me-1"></i>
                                                    {{ reservation.date|date('d/m/Y') }}
                                                </p>
                                                <p class="mb-1">
                                                    <i class="fas fa-clock me-1"></i>
                                                    {{ reservation.heure|date('H:i') }}
                                                </p>
                                                <p class="mb-2">
                                                    <i class="fas fa-users me-1"></i>
                                                    {{ reservation.nbPersonnes }} personnes
                                                </p>
                                                <span class="badge bg-primary">
                                                    Table {{ reservation.restaurantTable.numero }}
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {% endif %}
        </main>
    </div>
</div>

<style>
.avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
}
.avatar-sm {
    width: 40px;
    height: 40px;
}
.avatar-lg {
    width: 60px;
    height: 60px;
}
.avatar-title {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
}
.border-purple {
    border-left-color: #6f42c1 !important;
}
.bg-purple {
    background-color: #6f42c1 !important;
}
.text-purple {
    color: #6f42c1 !important;
}
.border-teal {
    border-left-color: #20c997 !important;
}
.bg-teal {
    background-color: #20c997 !important;
}
.text-teal {
    color: #20c997 !important;
}
.sidebar {
    background-color: #2c3e50;
    min-height: calc(100vh - 56px);
}
.sidebar .nav-link {
    color: #ecf0f1;
    padding: 10px 20px;
    border-radius: 0;
    transition: all 0.3s;
}
.sidebar .nav-link:hover {
    background-color: #34495e;
    color: #fff;
}
.sidebar .nav-link.active {
    background-color: #3498db;
    color: white;
}
.content-area {
    padding-top: 20px;
    background-color: #f8f9fa;
    min-height: calc(100vh - 56px);
}
</style>
{% endblock %}